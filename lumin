# Parse KEY=value arguments into variables
parse_args() {
  for arg in "$@"; do
    case "$arg" in
      URL=*) URL="${arg#URL=}" ;;
      REPO=*) REPO="${arg#REPO=}" ;;
      REPOS=*) REPOS="${arg#REPOS=}" ;;
      CONFIG=*) CONFIG="${arg#CONFIG=}" ;;
      OUTPUT=*) OUTPUT="${arg#OUTPUT=}" ;;
      ID=*) ID="${arg#ID=}" ;;
      CLEAN=*) CLEAN="${arg#CLEAN=}" ;;
      PIPELINE_TESTING=*) PIPELINE_TESTING="${arg#PIPELINE_TESTING=}" ;;
      SAFE_MODE=*) SAFE_MODE="${arg#SAFE_MODE=}" ;;
      LUMIN_DISABLE_GIT_WRITES=*) LUMIN_DISABLE_GIT_WRITES="${arg#LUMIN_DISABLE_GIT_WRITES=}" ;;
      REBUILD=*) REBUILD="${arg#REBUILD=}" ;;
      ROUTER=*) ROUTER="${arg#ROUTER=}" ;;
    esac
  done
}

is_git_url() {
  case "$1" in
    http://*|https://*|ssh://*|git@*) return 0 ;;
    *) return 1 ;;
  esac
}

# Check if Temporal is running and healthy
is_temporal_ready() {
  docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE exec -T temporal \
    temporal operator cluster health --address localhost:7233 2>/dev/null | grep -q "SERVING"
}

# Ensure containers are running with correct mounts
ensure_containers() {
  # If custom OUTPUT_DIR is set, always refresh worker to ensure correct volume mount
  # Docker compose will only recreate if the mount actually changed
  if [ -n "$OUTPUT_DIR" ]; then
    echo "Ensuring worker has correct output mount..."
    docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE up -d worker 2>/dev/null || true
  fi

  # Quick check: if Temporal is already healthy, we're good
  if is_temporal_ready; then
    return 0
  fi

  # Need to start containers
  echo "Starting Lumin containers..."
  if [ "$REBUILD" = "true" ]; then
    # Force rebuild without cache (use when code changes aren't being picked up)
    echo "Rebuilding with --no-cache..."
    docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE build --no-cache worker
  fi
  docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE up -d --build

  # Wait for Temporal to be ready
  echo "Waiting for Temporal to be ready..."
  for i in $(seq 1 30); do
    if is_temporal_ready; then
      echo "Temporal is ready!"
      return 0
    fi
    if [ "$i" -eq 30 ]; then
      echo "Timeout waiting for Temporal"
      exit 1
    fi
    sleep 2
  done
}

cmd_start() {
  parse_args "$@"

  # Safe mode defaults for scanning external repositories
  SAFE_MODE="${SAFE_MODE:-true}"
  if [ "$SAFE_MODE" = "true" ] && [ -z "$LUMIN_DISABLE_GIT_WRITES" ]; then
    LUMIN_DISABLE_GIT_WRITES="true"
  fi
  export LUMIN_DISABLE_GIT_WRITES

  # Validate required vars
  if [ -z "$URL" ]; then
    echo "ERROR: URL is required"
    echo "Usage: ./lumin start URL=<url> REPO=<name>"
    echo "       ./lumin start URL=<url> REPOS=<name1,name2>"
    exit 1
  fi

  if [ -z "$REPO" ] && [ -z "$REPOS" ]; then
    echo "ERROR: Either REPO or REPOS must be specified"
    echo "Usage: ./lumin start URL=<url> REPO=<name>"
    echo "       ./lumin start URL=<url> REPOS=<name1,name2>"
    exit 1
  fi

  # Check for API key (router mode can use alternative provider API keys)
  if [ -z "$ANTHROPIC_API_KEY" ] && [ -z "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
    if [ "$ROUTER" = "true" ] && { [ -n "$OPENAI_API_KEY" ] || [ -n "$OPENROUTER_API_KEY" ]; }; then
      # Router mode with alternative provider - set a placeholder for SDK init
      export ANTHROPIC_API_KEY="router-mode"
    else
      echo "ERROR: Set ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN in .env"
      echo "       (or use ROUTER=true with OPENAI_API_KEY or OPENROUTER_API_KEY)"
      exit 1
    fi
  fi

  # Determine container path for REPO/REPOS
  # - If REPOS is provided (comma-separated), use multiple repos
  # - If REPO is provided, use single repo (backward compatible)
  # - Each repo can be: git URL, folder name under ./repos/, or absolute path

  # Convert comma-separated REPOS to array
  if [ -n "$REPOS" ]; then
    REPO_LIST=$(echo "$REPOS" | tr ',' ' ')
    REPO_COUNT=$(echo "$REPO_LIST" | wc -w)
    echo "Processing $REPO_COUNT repositories..."
  elif [ -n "$REPO" ]; then
    REPO_LIST="$REPO"
    REPO_COUNT=1
  else
    echo "ERROR: Either REPO or REPOS must be specified"
    echo "Usage: ./lumin start URL=<url> REPO=<name>"
    echo "       ./lumin start URL=<url> REPOS=<name1,name2>"
    exit 1
  fi

  # Create isolated job directory for multiple repos or git URLs
  if [ "$REPO_COUNT" -gt 1 ] || ( [ -n "$REPOS" ] && is_git_url "$REPO_LIST" ); then
    mkdir -p ./repos
    JOB_ID="lumin-$(date +%Y%m%d-%H%M%S)-$RANDOM"
    CLONE_BASE="repos/$JOB_ID"
    mkdir -p "$CLONE_BASE"

    echo "Cloning $REPO_COUNT repositories into isolated workspace: $CLONE_BASE"

    for repo_item in $REPO_LIST; do
      if is_git_url "$repo_item"; then
        # Extract repo name from URL for folder name
        repo_name=$(basename "$repo_item" .git)
        repo_target="$CLONE_BASE/$repo_name"

        echo "  Cloning $repo_item -> $repo_target"
        git clone --depth 1 "$repo_item" "$repo_target"

        if [ "$SAFE_MODE" = "true" ] && [ -d "$repo_target/.git" ]; then
          for remote in $(git -C "$repo_target" remote 2>/dev/null); do
            git -C "$repo_target" remote set-url --push "$remote" DISABLED >/dev/null 2>&1 || true
          done
        fi
      else
        # Local folder - create symlink
        if [ -d "./repos/$repo_item" ]; then
          repo_target="$CLONE_BASE/$repo_item"
          if [ ! -L "$repo_target" ]; then
            ln -sf "../$repo_item" "$repo_target"
            echo "  Linking ./repos/$repo_item -> $repo_target"
          fi

          if [ "$SAFE_MODE" = "true" ] && [ -d "./repos/$repo_item/.git" ]; then
            for remote in $(git -C "./repos/$repo_item" remote 2>/dev/null); do
              git -C "./repos/$repo_item" remote set-url --push "$remote" DISABLED >/dev/null 2>&1 || true
            done
          fi
        else
          echo "ERROR: Repository not found at ./repos/$repo_item"
          exit 1
        fi
      fi
    done

    # Initialize git repository in parent directory for multi-repo mode
    # This enables git operations (checkpoint, rollback) across all cloned repos
    if [ "$REPO_COUNT" -gt 1 ]; then
      (cd "$CLONE_BASE" && git init && git config user.email "lumin@local" && git config user.name "Lumin Agent")
      # Remove .git from sub-repos in CLONE_BASE only (not original repos)
      # This prevents them from being treated as submodules
      for subdir in "$CLONE_BASE"/*/; do
        if [ -d "$subdir/.git" ]; then
          rm -rf "$subdir/.git"
        fi
      done
      (cd "$CLONE_BASE" && git add -A && git commit -m "Initial commit: multi-repo workspace" 2>/dev/null || true && echo "Initialized git workspace: $CLONE_BASE")
    fi

    if [ "$SAFE_MODE" = "true" ]; then
      echo "Safe mode: git push URLs disabled for isolated workspace"
    fi

    CONTAINER_REPO="/app/$CLONE_BASE"
    export REPOS="$REPOS"  # Pass REPOS to container for multi-repo mode
  else
    # Single local repo (backward compatible)
    repo_item="$REPO_LIST"
    if is_git_url "$repo_item"; then
      mkdir -p ./repos
      JOB_ID="lumin-$(date +%Y%m%d-%H%M%S)-$RANDOM"
      CLONE_DIR="./repos/$JOB_ID"

      echo "Cloning repository into isolated workspace: $CLONE_DIR"
      git clone --depth 1 "$repo_item" "$CLONE_DIR"

      if [ "$SAFE_MODE" = "true" ] && [ -d "$CLONE_DIR/.git" ]; then
        for remote in $(git -C "$CLONE_DIR" remote 2>/dev/null); do
          git -C "$CLONE_DIR" remote set-url --push "$remote" DISABLED >/dev/null 2>&1 || true
        done
        echo "Safe mode: git push URL disabled for isolated workspace"
      fi

      CONTAINER_REPO="/app/repos/$JOB_ID"
    else
      case "$repo_item" in
      /benchmarks/*|/repos/*)
        CONTAINER_REPO="$repo_item"
        ;;
      *)
        if [ ! -d "./repos/$repo_item" ]; then
          echo "ERROR: Repository not found at ./repos/$repo_item"
          echo ""
          echo "Place your target repository under the ./repos/ directory"
          exit 1
        fi
        CONTAINER_REPO="/app/repos/$repo_item"
        ;;
      esac

      if [ "$SAFE_MODE" = "true" ] && [ -d "./repos/$repo_item/.git" ]; then
        for remote in $(git -C "./repos/$repo_item" remote 2>/dev/null); do
          git -C "./repos/$repo_item" remote set-url --push "$remote" DISABLED >/dev/null 2>&1 || true
        done
        echo "Safe mode: git push URL disabled for local workspace"
      fi
    fi
  fi

  # Extract local repo path from CONTAINER_REPO for local file operations
  # Remove /app prefix and add ./ for local path (e.g., /app/repos/xxx -> ./repos/xxx)
  LOCAL_REPO_PATH="./${CONTAINER_REPO#/app}"

  if [ "$LUMIN_DISABLE_GIT_WRITES" = "true" ]; then
    echo "Safe mode: local git checkpoint/rollback/commit is disabled"
  fi

  # Handle custom OUTPUT directory
  # Export OUTPUT_DIR for docker-compose volume mount BEFORE starting containers
  if [ -n "$OUTPUT" ]; then
    # Create output directory with write permissions for container user (UID 1001)
    mkdir -p "$OUTPUT"
    chmod 777 "$OUTPUT"
    export OUTPUT_DIR="$OUTPUT"
  fi

  # Handle ROUTER flag - start claude-code-router for multi-model support
  if [ "$ROUTER" = "true" ]; then
    # Check if router is already running
    if docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE --profile router ps router 2>/dev/null | grep -q "running"; then
      echo "Router already running, skipping startup..."
    else
      echo "Starting claude-code-router..."

      # Check for provider API keys
      if [ -z "$OPENAI_API_KEY" ] && [ -z "$OPENROUTER_API_KEY" ]; then
        echo "WARNING: No provider API key set (OPENAI_API_KEY or OPENROUTER_API_KEY). Router may not work."
      fi

      # Start router with profile
      docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE --profile router up -d router

      # Give router a few seconds to start (health check disabled for now - TODO: debug later)
      echo "Waiting for router to start..."
      sleep 5
    fi

    # Set ANTHROPIC_BASE_URL to route through router
    export ANTHROPIC_BASE_URL="http://router:3456"
    # Set auth token to match router's APIKEY
    export ANTHROPIC_AUTH_TOKEN="lumin-router-key"
  fi

  # Ensure audit-logs directory exists with write permissions for container user (UID 1001)
  mkdir -p ./audit-logs
  chmod 777 ./audit-logs

  # Ensure repo deliverables directory is writable by container user (UID 1001)
  # Use LOCAL_REPO_PATH which is derived from CONTAINER_REPO (works for both local repos and git URLs)
  if [ -n "$LOCAL_REPO_PATH" ]; then
    mkdir -p "$LOCAL_REPO_PATH/deliverables"
    chmod 777 "$LOCAL_REPO_PATH/deliverables"
  fi

  # Ensure containers are running (starts them if needed)
  ensure_containers

  # Build optional args
  ARGS=""
  [ -n "$CONFIG" ] && ARGS="$ARGS --config $CONFIG"

  # Pass container path for output (where OUTPUT_DIR is mounted)
  # Also pass display path so client can show the host path to user
  if [ -n "$OUTPUT" ]; then
    ARGS="$ARGS --output /app/output --display-output $OUTPUT"
  fi

  [ "$PIPELINE_TESTING" = "true" ] && ARGS="$ARGS --pipeline-testing"

  # Pass REPOS if multiple repositories
  if [ -n "$REPOS" ]; then
    ARGS="$ARGS --repos $REPOS"
  fi

  # Set MCP working directory before starting workflow
  # Use CONTAINER_REPO directly (e.g., /app/repos/lumin-target)
  if [ -n "$CONTAINER_REPO" ]; then
    echo "Setting MCP working directory to: $CONTAINER_REPO"
    curl -s -X PUT http://localhost:8082/set-cwd \
      -H "Content-Type: application/json" \
      -d "{\"cwd\": \"$CONTAINER_REPO\"}" > /dev/null || true
  fi

  # Run the client to submit workflow
  docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE exec -T worker \
    node dist/temporal/client.js "$URL" "$CONTAINER_REPO" $ARGS
}

cmd_logs() {
  parse_args "$@"

  if [ -z "$ID" ]; then
    echo "ERROR: ID is required"
    echo "Usage: ./lumin logs ID=<workflow-id>"
    exit 1
  fi

  # Auto-discover the workflow log file
  # 1. Check default location first
  # 2. Search common output directories
  # 3. Fall back to find command
  WORKFLOW_LOG=""

  if [ -f "./audit-logs/${ID}/workflow.log" ]; then
    WORKFLOW_LOG="./audit-logs/${ID}/workflow.log"
  else
    # Search for the workflow directory (handles custom OUTPUT paths)
    FOUND=$(find . -maxdepth 3 -path "*/${ID}/workflow.log" -type f 2>/dev/null | head -1)
    if [ -n "$FOUND" ]; then
      WORKFLOW_LOG="$FOUND"
    fi
  fi

  if [ -n "$WORKFLOW_LOG" ]; then
    echo "Tailing workflow log: $WORKFLOW_LOG"
    tail -f "$WORKFLOW_LOG"
  else
    echo "ERROR: Workflow log not found for ID: $ID"
    echo ""
    echo "Possible causes:"
    echo "  - Workflow hasn't started yet"
    echo "  - Workflow ID is incorrect"
    echo ""
    echo "Check: ./lumin query ID=$ID for workflow details"
    exit 1
  fi
}

cmd_query() {
  parse_args "$@"

  if [ -z "$ID" ]; then
    echo "ERROR: ID is required"
    echo "Usage: ./lumin query ID=<workflow-id>"
    exit 1
  fi

  docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE exec -T worker \
    node dist/temporal/query.js "$ID"
}

cmd_stop() {
  parse_args "$@"

  if [ "$CLEAN" = "true" ]; then
    docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE --profile router down -v
  else
    docker compose -f "$COMPOSE_FILE" $COMPOSE_OVERRIDE --profile router down
  fi
}

# Main command dispatch
case "${1:-help}" in
  start)
    shift
    cmd_start "$@"
    ;;
  logs)
    shift
    cmd_logs "$@"
    ;;
  query)
    shift
    cmd_query "$@"
    ;;
  stop)
    shift
    cmd_stop "$@"
    ;;
  help|--help|-h|*)
    show_help
    ;;
esac
